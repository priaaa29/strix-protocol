# ── Stellar Network ────────────────────────────────────────────────────────────
# "testnet" or "mainnet"
NETWORK=testnet
RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── Contract Addresses (fill after deployment) ─────────────────────────────────
PRICING_ENGINE_ID=
VAULT_ID=
OPTION_MARKET_ID=
# USDC SAC (classic USDC; issuer GBPOKGY3JM6JZAAMKNYNDTKKWXH46SI3PLLJX2DARZ4QXS7WVL4WYQBA)
USDC_TOKEN_ID=CBA4XQJCNN76UX3AQ63EKQXQMMIHTVENTXV2QNXLCOPMYIXAESQZUDZQ
# Reflector testnet oracle (XLM/USD) — 14-decimal `lastprice(asset)` interface.
# The on-chain pricing-engine + option-market call lastprice; do not swap this
# for a different oracle without updating the contract source as well.
ORACLE_ID=CCYOZJCOPG34LLQQ7N24YXBM7LL62R7ONMZ3G6WZAAYPB5OYKOMJRN63

# ── Admin keypair ──────────────────────────────────────────────────────────────
# Public key used as the simulation source account for read-only RPC calls.
ADMIN_ADDRESS=

# Name of the key in your local Stellar CLI keystore (stellar keys ls).
# Used by settlement-keeper to sign transactions.
# NEVER commit the actual secret key — store it only in the keystore.
STELLAR_KEY_ALIAS=

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:3000

# ── Security ───────────────────────────────────────────────────────────────────
# Secret key for GET /api/feedback (admin endpoint).
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=
