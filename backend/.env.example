# ── Stellar Network ────────────────────────────────────────────────────────
# "testnet" or "mainnet"
NETWORK=testnet
RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── Contract Addresses (fill after deployment) ─────────────────────────────
PRICING_ENGINE_ID=
VAULT_ID=
OPTION_MARKET_ID=
USDC_TOKEN_ID=
ORACLE_ID=

# ── Admin keypair ──────────────────────────────────────────────────────────
# Public key used as the simulation source account for read-only RPC calls.
ADMIN_ADDRESS=

# Name of the key in your local Stellar CLI keystore (stellar keys ls).
# Used by oracle-keeper and settlement-keeper to sign transactions.
# NEVER commit the actual secret key — store it only in the keystore.
STELLAR_KEY_ALIAS=

# ── Oracle Keeper ──────────────────────────────────────────────────────────
# Simulated XLM/USDC price for the mock oracle (14-decimal format).
# 0.12 USDC = 12000000000000. Ignored on mainnet (Reflector is autonomous).
ORACLE_PRICE_14DEC=12000000000000

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:3000

# ── Security ───────────────────────────────────────────────────────────────
# Secret key for GET /api/feedback (admin endpoint).
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=
