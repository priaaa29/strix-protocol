# Strix Protocol Frontend — Environment Variables
# Copy to .env.local and fill in values from .deployed.json after running scripts/deploy.sh

# Network: testnet | mainnet
NEXT_PUBLIC_NETWORK=testnet

# Soroban RPC endpoint
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org

# Horizon API
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# Contract IDs (from .deployed.json)
NEXT_PUBLIC_PRICING_ENGINE_ID=
NEXT_PUBLIC_VAULT_ID=
NEXT_PUBLIC_OPTION_MARKET_ID=

# Static: testnet USDC and Reflector oracle (14-decimal)
# USDC: classic USDC SAC, issuer GBPOKGY3JM6JZAAMKNYNDTKKWXH46SI3PLLJX2DARZ4QXS7WVL4WYQBA
NEXT_PUBLIC_USDC_TOKEN_ID=CBA4XQJCNN76UX3AQ63EKQXQMMIHTVENTXV2QNXLCOPMYIXAESQZUDZQ
# Reflector testnet (XLM/USD), 14-decimal `lastprice` interface
NEXT_PUBLIC_ORACLE_ID=CCYOZJCOPG34LLQQ7N24YXBM7LL62R7ONMZ3G6WZAAYPB5OYKOMJRN63

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:3001
